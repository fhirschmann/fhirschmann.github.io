---
import Base from '../layouts/Base.astro';

const contacts = [
  { label: 'github', handle: 'github.com/fhirschmann', href: 'https://github.com/fhirschmann' },
  { label: 'linkedin', handle: 'linkedin.com/in/fhirschmann', href: 'https://linkedin.com/in/fhirschmann' },
  { label: 'xing', handle: 'xing.com/profile/Fabian_Hirschmann2', href: 'https://www.xing.com/profile/Fabian_Hirschmann2' },
];
---

<Base
  title="Fabian Hirschmann — Machine Learning at Google"
  description="Fabian Hirschmann is a machine learning specialist working at Google."
>
  <main class="wrap">
    <section class="hero">
      <figure class="portrait reveal" style="--d:.5s">
        <img src="/me-pixel.jpg" alt="Pixelated portrait of Fabian Hirschmann" width="64" height="58" />
        <figcaption>me.jpg — 64×58 px</figcaption>
      </figure>

      <p class="bootline reveal" style="--d:.1s">
        &gt; boot sequence complete<br />
        &gt; all systems <b>operational</b>
      </p>

      <h1 class="reveal" style="--d:.25s">
        Fabian<br />Hirschmann<span class="cursor">▮</span>
      </h1>

      <p class="whoami reveal" style="--d:.4s">
        <span class="ps1">$ whoami</span>
        <span class="out">machine learning specialist @ <a href="https://google.com" rel="noopener">google</a></span>
      </p>
    </section>

    <section id="contact" class="section reveal" style="--d:.65s">
      <p class="section-cmd">$ ls -la ./contact</p>
      <div class="section-head">
        <span class="index"></span>
        <h2>Contact</h2>
      </div>
      <ul class="rows">
        {
          contacts.map((c, i) => (
            <li>
              <a class="row" href={c.href} target="_blank" rel="noopener">
                <span class="row-num">-rw-</span>
                <span class="row-title">{c.label}</span>
                <span class="row-meta">{c.handle}</span>
                <span class="row-arrow">[↗]</span>
              </a>
            </li>
          ))
        }
        <li>
          <a class="row" id="email-row">
            <span class="row-num">-rw-</span>
            <span class="row-title">email</span>
            <span class="row-meta" id="email-meta">[ encrypted — javascript required ]</span>
            <span class="row-arrow">[↗]</span>
          </a>
        </li>
      </ul>
    </section>
  </main>

  <script>
    // Assemble the address at runtime from char codes so neither the address
    // nor readable fragments of it end up in the served HTML/JS (a plain
    // String.fromCharCode(64) would get constant-folded to "@" by the bundler).
    const codes = [102, 97, 98, 105, 97, 110, 64, 104, 105, 114, 115, 99, 104, 109, 97, 110, 110, 46, 101, 109, 97, 105, 108];
    const addr = codes.map((c) => String.fromCharCode(c)).join('');
    const row = document.getElementById('email-row') as HTMLAnchorElement;
    const meta = document.getElementById('email-meta')!;
    row.href = 'mailto:' + addr;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      meta.textContent = addr;
    } else {
      const glyphs = '01#$%&?!<>[]{}=*';
      let frame = 0;
      const frames = 16;
      const tick = () => {
        frame++;
        const solved = Math.floor((frame / frames) * addr.length);
        meta.textContent =
          addr.slice(0, solved) +
          Array.from({ length: addr.length - solved }, () => glyphs[(Math.random() * glyphs.length) | 0]).join('');
        if (solved < addr.length) setTimeout(tick, 40);
      };
      tick();
    }
  </script>
</Base>
