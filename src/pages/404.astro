---
import Base from '../layouts/Base.astro';
---

<Base
  title="404 — Fabian Hirschmann"
  description="Page not found."
>
  <main class="wrap">
    <p class="section-cmd reveal" style="--d:0s; margin-top: 2.2rem;">$ cat ./requested-page</p>
    <h1 class="page-title reveal" style="--d:.1s; margin-top: 0;">Error 404</h1>
    <div class="prose reveal" style="--d:.2s">
      <p>segmentation fault (core dumped)</p>
      <p>the page you are looking for does not exist.</p>
      <p><a href="/">$ cd ~</a></p>
    </div>
  </main>
</Base>
